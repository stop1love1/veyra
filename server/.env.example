# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/veyra

# JWT secrets — REQUIRED. The app refuses to start unless these are set to
# strong, unique values (min 16 chars, must differ from each other).
# Generate e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Token lifetimes (optional; defaults: 15m access / 7d refresh)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=7d

# HTTP port
PORT=3001

# Allowed CORS origins (comma-separated). Defaults to the local client.
CLIENT_ORIGIN=http://localhost:3000
